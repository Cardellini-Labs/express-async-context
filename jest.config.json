{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "collectCoverage": true,
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/types.ts"
  ],
  "testPathIgnorePatterns": [
    "/lib/",
    "/esm/",
    "/examples/",
    "/node_modules/"
  ]
}
